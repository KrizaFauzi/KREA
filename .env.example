# --- KREA configuration ---

# Required: your Google AI Studio API key (https://aistudio.google.com/apikey).
# Free tier, no credit card needed. GEMINI_API_KEY also works as an alias.
GOOGLE_API_KEY=

# The single model KREA runs on: Google Gemma 4 31B.
MODEL=gemma-4-31b-it

# Max output tokens per model turn.
MAX_TOKENS=8192

# --- TikTok research (RapidAPI) — part 1 "Riset Produk" ---
# Get a key at https://rapidapi.com and subscribe to a TikTok scraper API.
# Leave RAPIDAPI_KEY empty to skip live data (KREA falls back to brainstorming).
RAPIDAPI_KEY=
# Host/path default to the "tiktok-scraper7" API. Change if you use another provider.
RAPIDAPI_HOST=tiktok-scraper7.p.rapidapi.com
TIKTOK_SEARCH_PATH=/feed/search
# Some providers name the keyword param "keyword" instead of "keywords".
TIKTOK_QUERY_PARAM=keywords
TIKTOK_REGION=ID

# Comma-separated list of allowed CORS origins for the frontend dev server.
CORS_ORIGINS=http://localhost:5173
